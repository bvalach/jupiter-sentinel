# Sentinel public prototype configuration
# Copy to .env and adjust for your machine.

# Output directories. Relative paths are resolved from the repository root.
AUDIT_DIR=daily
HISTORY_FILE=history/summaries.jsonl

# Host label shown in reports.
HOSTNAME_LABEL=workstation-01

# CLI commands. These are expected to authenticate locally via OAuth/session login.
CLAUDE_CLI=claude
CODEX_CLI=codex

# Model selection
CLAUDE_MODEL_INTEL=opus
CLAUDE_MODEL_MERGE=sonnet
CODEX_MODEL=o3

# Phase toggles
ENABLE_THREAT_INTEL=true
ENABLE_FORENSIC_AUDIT=true
ENABLE_MERGE_REPORT=true
ENABLE_NOTIFICATIONS=false

# Turn limits for CLI agent phases
MAX_TURNS_INTEL=12
MAX_TURNS_MERGE=8

# Scanner behavior
DEBIAN_SUITE=auto
RUN_NETWORK_AUDITS=false
PROJECT_PATHS=
CHECKSUM_FILES=/etc/passwd:/etc/group:/etc/sudoers:/etc/ssh/sshd_config
SUID_SCAN_PATHS=/
WORLD_WRITABLE_PATHS=/etc:/usr/local:/opt
PROJECT_SCAN_MAX_FILE_BYTES=1048576
MAX_SECRET_MATCHES=50

# Optional Telegram notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
